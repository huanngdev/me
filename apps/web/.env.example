# GitHub (existing)
GITHUB_TOKEN=

# Postgres (Drizzle ORM)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Redis (TCP connection string — ioredis)
REDIS_URL=redis://default:password@host:6379

# 32+ random bytes. Generate with: openssl rand -hex 32
VIEW_HASH_SALT=

# football-data.org — free token for live World Cup scores (optional).
# Register at https://www.football-data.org/client/register
# Without it, /world-cup falls back to the openfootball backbone (no in-play scores).
FOOTBALL_DATA_TOKEN=
