    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "next": "16.2.6",
    "prettier": "^3.7.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "^5"
  },
  "peerDependencies": {
    "next": "^16",
    "react": "^19",
    "react-dom": "^19"
