{
  "name": "@repo/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./functions": "./src/functions/index.ts",
    "./ui": "./src/ui/index.ts",
